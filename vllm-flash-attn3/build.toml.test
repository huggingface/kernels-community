# Copy this file to `build.toml` for testing the build without
# waiting for hours. Produces a very minimal, no-frills version
# of vllm-flash-attn3.

[general]
name = "vllm-flash-attn3"
version = 1
license = "Apache-2.0"
backends = ["cuda"]

[general.cuda]
minver = "12.6"
# ptxas fails on 13.2, but the 13.0 build is backwards compatible.
maxver = "13.0"

[general.hub]
repo-id = "kernels-community/vllm-flash-attn3"

[torch]
stable-abi = "2.9"
src = [
    "flash-attn/flash_api_stable.cpp",
]
cxx-flags = [
    "-DFLASHATTENTION_DISABLE_HDIM64",
    "-DFLASHATTENTION_DISABLE_HDIM96",
    "-DFLASHATTENTION_DISABLE_HDIM192",
    "-DFLASHATTENTION_DISABLE_HDIM256",
    "-DFLASHATTENTION_DISABLE_SPLIT",
    "-DFLASHATTENTION_DISABLE_PAGEDKV",
    "-DFLASHATTENTION_DISABLE_APPENDKV",
    "-DFLASHATTENTION_DISABLE_SOFTCAP",
    "-DFLASHATTENTION_DISABLE_PACKGQA",
    "-DFLASHATTENTION_DISABLE_FP8",
    "-DFLASHATTENTION_DISABLE_BACKWARD",
]

[kernel.flash_attn]
backend = "cuda"
cuda-capabilities = [
    "8.0",
    "9.0a",
]
cuda-flags = [
    "-O3",
    "-std=c++17",
    "--ftemplate-backtrace-limit=0",
    "--use_fast_math",
    "-DCUTE_SM90_EXTENDED_MMA_SHAPES_ENABLED",
    "-DCUTLASS_ENABLE_GDC_FOR_SM90",
    "--expt-relaxed-constexpr",
    "--expt-extended-lambda",
    "--use_fast_math",
    "-DNDEBUG",
    "-DFLASHATTENTION_DISABLE_HDIM64",
    "-DFLASHATTENTION_DISABLE_HDIM96",
    "-DFLASHATTENTION_DISABLE_HDIM192",
    "-DFLASHATTENTION_DISABLE_HDIM256",
    "-DFLASHATTENTION_DISABLE_SPLIT",
    "-DFLASHATTENTION_DISABLE_PAGEDKV",
    "-DFLASHATTENTION_DISABLE_APPENDKV",
    "-DFLASHATTENTION_DISABLE_SOFTCAP",
    "-DFLASHATTENTION_DISABLE_PACKGQA",
    "-DFLASHATTENTION_DISABLE_FP8",
    "-DFLASHATTENTION_DISABLE_BACKWARD",
]
cxx-flags = [
    "-DFLASHATTENTION_DISABLE_HDIM64",
    "-DFLASHATTENTION_DISABLE_HDIM96",
    "-DFLASHATTENTION_DISABLE_HDIM192",
    "-DFLASHATTENTION_DISABLE_HDIM256",
    "-DFLASHATTENTION_DISABLE_SPLIT",
    "-DFLASHATTENTION_DISABLE_PAGEDKV",
    "-DFLASHATTENTION_DISABLE_APPENDKV",
    "-DFLASHATTENTION_DISABLE_SOFTCAP",
    "-DFLASHATTENTION_DISABLE_PACKGQA",
    "-DFLASHATTENTION_DISABLE_FP8",
    "-DFLASHATTENTION_DISABLE_BACKWARD",
]

depends = [
    "torch",
    "cutlass_3_9",
]
src = [
    "flash-attn/cuda_check.h",
    "flash-attn/flash_fwd_combine.cu",
    "flash-attn/flash_fwd_combine_kernel.h",
    "flash-attn/flash_fwd_combine_launch_template.h",
    "flash-attn/flash.h",
    "flash-attn/flash_prepare_scheduler.cu",
    "flash-attn/heuristics.h",
    "flash-attn/seqlen.h",
    "flash-attn/static_switch.h",
    "flash-attn/tile_size.h",
    "flash-attn/utils.h",
]

[kernel.flash_attn_sm90]
backend = "cuda"
cuda-capabilities = ["9.0a"]
cuda-flags = [
    "-O3",
    "-std=c++17",
    "--ftemplate-backtrace-limit=0",
    "--use_fast_math",
    "-DCUTE_SM90_EXTENDED_MMA_SHAPES_ENABLED",
    "-DCUTLASS_ENABLE_GDC_FOR_SM90",
    "--expt-relaxed-constexpr",
    "--expt-extended-lambda",
    "--use_fast_math",
    "-DNDEBUG",
    "-DFLASHATTENTION_DISABLE_HDIM64",
    "-DFLASHATTENTION_DISABLE_HDIM96",
    "-DFLASHATTENTION_DISABLE_HDIM192",
    "-DFLASHATTENTION_DISABLE_HDIM256",
    "-DFLASHATTENTION_DISABLE_SPLIT",
    "-DFLASHATTENTION_DISABLE_PAGEDKV",
    "-DFLASHATTENTION_DISABLE_APPENDKV",
    "-DFLASHATTENTION_DISABLE_SOFTCAP",
    "-DFLASHATTENTION_DISABLE_PACKGQA",
    "-DFLASHATTENTION_DISABLE_FP8",
    "-DFLASHATTENTION_DISABLE_BACKWARD",
]
cxx-flags = [
    "-DFLASHATTENTION_DISABLE_HDIM64",
    "-DFLASHATTENTION_DISABLE_HDIM96",
    "-DFLASHATTENTION_DISABLE_HDIM192",
    "-DFLASHATTENTION_DISABLE_HDIM256",
    "-DFLASHATTENTION_DISABLE_SPLIT",
    "-DFLASHATTENTION_DISABLE_PAGEDKV",
    "-DFLASHATTENTION_DISABLE_APPENDKV",
    "-DFLASHATTENTION_DISABLE_SOFTCAP",
    "-DFLASHATTENTION_DISABLE_PACKGQA",
    "-DFLASHATTENTION_DISABLE_FP8",
    "-DFLASHATTENTION_DISABLE_BACKWARD",
]
depends = [
    "torch",
    "cutlass_3_9",
]
include = ["flash-attn"]
src = [
    "flash-attn/block.h",
    "flash-attn/copy_sm90_bulk_reduce.hpp",
    "flash-attn/epilogue_bwd.hpp",
    "flash-attn/epilogue_fwd.hpp",
    "flash-attn/flash.h",
    "flash-attn/flash_bwd_kernel_sm80.h",
    "flash-attn/flash_bwd_kernel_sm90.h",
    "flash-attn/flash_bwd_launch_template.h",
    "flash-attn/flash_bwd_postprocess_kernel.h",
    "flash-attn/flash_bwd_preprocess_kernel.h",
    "flash-attn/flash_fwd_launch_template.h",
    "flash-attn/flash_fwd_kernel_sm80.h",
    "flash-attn/flash_fwd_kernel_sm90.h",
    "flash-attn/heuristics.h",
    "flash-attn/mainloop_bwd_sm80.hpp",
    "flash-attn/mainloop_fwd_sm80.hpp",
    "flash-attn/mainloop_bwd_sm90_tma_gmma_ws.hpp",
    "flash-attn/mainloop_fwd_sm90_tma_gmma_ws.hpp",
    "flash-attn/mask.h",
    "flash-attn/named_barrier.hpp",
    "flash-attn/pack_gqa.h",
    "flash-attn/paged_kv.h",
    "flash-attn/rotary.h",
    "flash-attn/sm90_pipeline_no_cluster.hpp",
    "flash-attn/softmax.h",
    "flash-attn/tile_size.h",
    "flash-attn/tile_scheduler.hpp",
    "flash-attn/instantiations/flash_fwd_hdim128_bf16_sm90.cuh",
    "flash-attn/instantiations/flash_fwd_hdim128_fp16_sm90.cuh",
    "flash-attn/instantiations/flash_fwd_hdim192_128_bf16_sm90.cuh",
    "flash-attn/instantiations/flash_fwd_hdim192_128_fp16_sm90.cuh",
    "flash-attn/instantiations/flash_fwd_hdim192_bf16_sm90.cuh",
    "flash-attn/instantiations/flash_fwd_hdim192_fp16_sm90.cuh",
    "flash-attn/instantiations/flash_fwd_hdim256_bf16_sm90.cuh",
    "flash-attn/instantiations/flash_fwd_hdim256_fp16_sm90.cuh",
    "flash-attn/instantiations/flash_fwd_hdim64_256_bf16_sm90.cuh",
    "flash-attn/instantiations/flash_fwd_hdim64_256_fp16_sm90.cuh",
    "flash-attn/instantiations/flash_fwd_hdim64_512_bf16_sm90.cuh",
    "flash-attn/instantiations/flash_fwd_hdim64_512_fp16_sm90.cuh",
    "flash-attn/instantiations/flash_fwd_hdim64_bf16_sm90.cuh",
    "flash-attn/instantiations/flash_fwd_hdim64_fp16_sm90.cuh",
    "flash-attn/instantiations/flash_fwd_hdim96_bf16_sm90.cuh",
    "flash-attn/instantiations/flash_fwd_hdim96_fp16_sm90.cuh",
    "flash-attn/instantiations/flash_fwd_hdimall_bf16_sm90.cu",
    "flash-attn/instantiations/flash_fwd_hdimall_fp16_sm90.cu",
    "flash-attn/instantiations/flash_fwd_hdimdiff_bf16_sm90.cu",
    "flash-attn/instantiations/flash_fwd_hdimdiff_fp16_sm90.cu",
]

[kernel.flash_attn_sm80]
backend = "cuda"
cuda-capabilities = ["8.0"]
cuda-flags = [
    "-O3",
    "-std=c++17",
    "--ftemplate-backtrace-limit=0",
    "--use_fast_math",
    "-DCUTE_SM90_EXTENDED_MMA_SHAPES_ENABLED",
    "-DCUTLASS_ENABLE_GDC_FOR_SM90",
    "--expt-relaxed-constexpr",
    "--expt-extended-lambda",
    "--use_fast_math",
    "-DNDEBUG",
    "-DFLASHATTENTION_DISABLE_HDIM64",
    "-DFLASHATTENTION_DISABLE_HDIM96",
    "-DFLASHATTENTION_DISABLE_HDIM192",
    "-DFLASHATTENTION_DISABLE_HDIM256",
    "-DFLASHATTENTION_DISABLE_SPLIT",
    "-DFLASHATTENTION_DISABLE_PAGEDKV",
    "-DFLASHATTENTION_DISABLE_APPENDKV",
    "-DFLASHATTENTION_DISABLE_SOFTCAP",
    "-DFLASHATTENTION_DISABLE_PACKGQA",
    "-DFLASHATTENTION_DISABLE_FP8",
    "-DFLASHATTENTION_DISABLE_BACKWARD",
]
cxx-flags = [
    "-DFLASHATTENTION_DISABLE_HDIM64",
    "-DFLASHATTENTION_DISABLE_HDIM96",
    "-DFLASHATTENTION_DISABLE_HDIM192",
    "-DFLASHATTENTION_DISABLE_HDIM256",
    "-DFLASHATTENTION_DISABLE_SPLIT",
    "-DFLASHATTENTION_DISABLE_PAGEDKV",
    "-DFLASHATTENTION_DISABLE_APPENDKV",
    "-DFLASHATTENTION_DISABLE_SOFTCAP",
    "-DFLASHATTENTION_DISABLE_PACKGQA",
    "-DFLASHATTENTION_DISABLE_FP8",
    "-DFLASHATTENTION_DISABLE_BACKWARD",
]
depends = [
    "torch",
    "cutlass_3_9",
]
include = ["flash-attn"]
src = [
    "flash-attn/block.h",
    "flash-attn/copy_sm90_bulk_reduce.hpp",
    "flash-attn/epilogue_bwd.hpp",
    "flash-attn/epilogue_fwd.hpp",
    "flash-attn/flash.h",
    "flash-attn/flash_bwd_kernel_sm80.h",
    "flash-attn/flash_bwd_kernel_sm90.h",
    "flash-attn/flash_bwd_launch_template.h",
    "flash-attn/flash_bwd_postprocess_kernel.h",
    "flash-attn/flash_bwd_preprocess_kernel.h",
    "flash-attn/flash_fwd_launch_template.h",
    "flash-attn/flash_fwd_kernel_sm80.h",
    "flash-attn/flash_fwd_kernel_sm90.h",
    "flash-attn/heuristics.h",
    "flash-attn/mainloop_bwd_sm80.hpp",
    "flash-attn/mainloop_fwd_sm80.hpp",
    "flash-attn/mainloop_bwd_sm90_tma_gmma_ws.hpp",
    "flash-attn/mainloop_fwd_sm90_tma_gmma_ws.hpp",
    "flash-attn/mask.h",
    "flash-attn/named_barrier.hpp",
    "flash-attn/pack_gqa.h",
    "flash-attn/paged_kv.h",
    "flash-attn/rotary.h",
    "flash-attn/sm90_pipeline_no_cluster.hpp",
    "flash-attn/softmax.h",
    "flash-attn/tile_size.h",
    "flash-attn/tile_scheduler.hpp",
    "flash-attn/instantiations/flash_fwd_hdim128_bf16_sm80.cu",
    "flash-attn/instantiations/flash_fwd_hdim128_fp16_sm80.cu",
    "flash-attn/instantiations/flash_fwd_hdim192_bf16_sm80.cu",
    "flash-attn/instantiations/flash_fwd_hdim192_fp16_sm80.cu",
    "flash-attn/instantiations/flash_fwd_hdim256_bf16_sm80.cu",
    "flash-attn/instantiations/flash_fwd_hdim256_fp16_sm80.cu",
    "flash-attn/instantiations/flash_fwd_hdim64_bf16_sm80.cu",
    "flash-attn/instantiations/flash_fwd_hdim64_fp16_sm80.cu",
    "flash-attn/instantiations/flash_fwd_hdim96_bf16_sm80.cu",
    "flash-attn/instantiations/flash_fwd_hdim96_fp16_sm80.cu",
]
